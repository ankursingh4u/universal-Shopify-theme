<div class="section">
  <div class="page-width">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
      <h1>My Account</h1>
      <a href="{{ routes.account_logout_url }}" class="btn btn--secondary btn--small">Log out</a>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
      <div>
        <h2 class="h3" style="margin-bottom: 1rem;">Order History</h2>
        {%- if customer.orders.size > 0 -%}
          {%- for order in customer.orders -%}
            <div style="padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <a href="{{ order.customer_url }}" style="font-weight: 600;">{{ order.name }}</a>
                <span style="font-size: 0.875rem; color: var(--color-text-light);">{{ order.created_at | date: '%B %d, %Y' }}</span>
              </div>
              <p style="font-size: 0.875rem; color: var(--color-text-light); margin-top: 0.25rem;">
                {{ order.financial_status_label }} &middot; {{ order.fulfillment_status_label }} &middot; {{ order.total_price | money }}
              </p>
            </div>
          {%- endfor -%}
        {%- else -%}
          <p style="color: var(--color-text-light);">You haven't placed any orders yet.</p>
        {%- endif -%}
      </div>

      <div>
        <h2 class="h3" style="margin-bottom: 1rem;">Account Details</h2>
        <p style="font-weight: 600;">{{ customer.name }}</p>
        <p style="color: var(--color-text-light);">{{ customer.email }}</p>
        {%- if customer.default_address -%}
          <div style="margin-top: 1rem; font-size: 0.9375rem; line-height: 1.6;">
            {{ customer.default_address | format_address }}
          </div>
        {%- endif -%}
        <a href="{{ routes.account_addresses_url }}" style="display: inline-block; margin-top: 1rem; font-size: 0.875rem; text-decoration: underline;">
          Manage addresses
        </a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer account",
  "tag": "section",
  "settings": []
}
{% endschema %}
