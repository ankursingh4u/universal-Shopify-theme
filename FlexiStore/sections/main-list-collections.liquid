<div class="section">
  <div class="page-width">
    <div class="section-header">
      <h1>{{ 'collections.general.title' | t }}</h1>
    </div>

    <div class="grid grid--{{ section.settings.columns }}">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="category-card">
          {%- if collection.image -%}
            <img
              src="{{ collection.image | image_url: width: 600 }}"
              alt="{{ collection.title | escape }}"
              loading="lazy"
              width="600"
              height="800"
            >
          {%- elsif collection.products.first and collection.products.first.featured_image -%}
            <img
              src="{{ collection.products.first.featured_image | image_url: width: 600 }}"
              alt="{{ collection.title | escape }}"
              loading="lazy"
              width="600"
              height="800"
            >
          {%- else -%}
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="category-card__overlay"></div>
          <div class="category-card__content">
            <h2 class="category-card__title">{{ collection.title | escape }}</h2>
            <p class="category-card__count">{{ collection.products_count }} {{ 'collections.general.product_count' | t: count: collection.products_count }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection list page",
  "tag": "section",
  "class": "section-list-collections",
  "settings": [
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ]
}
{% endschema %}
