<div class="section">
  <div class="page-width search-page">
    <h1>{{ 'templates.search.title' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search__form">
      <input
        type="search"
        name="q"
        class="field__input"
        placeholder="{{ 'templates.search.placeholder' | t }}"
        value="{{ search.terms | escape }}"
        aria-label="{{ 'templates.search.placeholder' | t }}"
      >
      <button type="submit" class="btn btn--primary">{{ 'general.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="search__results-count">
          {{ 'templates.search.results_for' | t: terms: search.terms }}
          ({{ search.results_count }})
        </p>

        <div class="grid grid--{{ section.settings.columns }}">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <div>
                {% render 'card-product', product: item %}
              </div>
            {%- elsif item.object_type == 'article' -%}
              <div class="article-card">
                {%- if item.image -%}
                  <div class="article-card__media">
                    <a href="{{ item.url }}">
                      <img src="{{ item.image | image_url: width: 600 }}" alt="{{ item.title | escape }}" loading="lazy" width="600">
                    </a>
                  </div>
                {%- endif -%}
                <div class="article-card__content">
                  <h3 class="article-card__title">
                    <a href="{{ item.url }}">{{ item.title | escape }}</a>
                  </h3>
                  <p class="article-card__excerpt">{{ item.content | strip_html | truncatewords: 20 }}</p>
                </div>
              </div>
            {%- elsif item.object_type == 'page' -%}
              <div>
                <h3 class="h4"><a href="{{ item.url }}">{{ item.title | escape }}</a></h3>
                <p class="text-light" style="font-size: 0.875rem;">{{ item.content | strip_html | truncatewords: 20 }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if search.results_count > section.settings.results_per_page -%}
          {%- paginate search.results by section.settings.results_per_page -%}
            {%- if paginate.pages > 1 -%}
              <div class="collection__pagination">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}">&laquo;</a>
                {%- endif -%}
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}">{{ part.title }}</a>
                  {%- else -%}
                    <span class="is-current">{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}
                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}">&raquo;</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endpaginate -%}
        {%- endif -%}
      {%- else -%}
        <p>{{ 'templates.search.no_results' | t: terms: search.terms }}</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Search results",
  "tag": "section",
  "class": "section-search",
  "settings": [
    {
      "type": "select",
      "id": "columns",
      "label": "Grid columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ]
}
{% endschema %}
