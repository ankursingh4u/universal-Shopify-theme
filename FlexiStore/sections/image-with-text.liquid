{%- capture niche_about_heading -%}{%- render 'niche-value', key: 'about_heading' -%}{%- endcapture -%}
{%- capture niche_about_text -%}{%- render 'niche-value', key: 'about_text' -%}{%- endcapture -%}

<div class="section{% if section.settings.use_alt_bg %} section--alt{% endif %}">
  <div class="page-width">
    <div class="image-with-text{% if section.settings.layout == 'image_right' %} image-with-text--reverse{% endif %}">
      <div class="image-with-text__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" width="800" height="{{ 800 | divided_by: section.settings.image.aspect_ratio | round }}">
        {%- else -%}
          {%- capture niche_story_image -%}{%- render 'niche-value', key: 'story_image' -%}{%- endcapture -%}
          {%- assign niche_story_image = niche_story_image | strip -%}
          {%- if niche_story_image != blank -%}
            <img src="{{ niche_story_image }}" alt="Our story" loading="lazy" width="800" height="800" onerror="this.style.display='none'">
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="image-with-text__content">
        {%- if section.settings.subtitle != blank -%}
          <p class="text-light" style="font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.5rem;">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <h2 class="image-with-text__title">{%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}{{ niche_about_heading }}{%- endif -%}</h2>

        <div class="image-with-text__text">{%- if section.settings.text != blank -%}{{ section.settings.text }}{%- else -%}<p>{{ niche_about_text }}</p>{%- endif -%}</div>

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
        {%- else -%}
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Shop all</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "class": "section-image-with-text",
  "settings": [
    { "type": "paragraph", "content": "Leave blank to auto-fill based on your store niche." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "layout", "label": "Image position", "options": [{ "value": "image_left", "label": "Image left" }, { "value": "image_right", "label": "Image right" }], "default": "image_left" },
    { "type": "text", "id": "subtitle", "label": "Subtitle" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "text", "label": "Description" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "use_alt_bg", "label": "Use alternate background color", "default": false }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
