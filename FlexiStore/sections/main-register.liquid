<div class="section">
  <div class="page-width">
    <div style="max-width: 450px; margin: 0 auto; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Create Account</h1>

      {%- form 'create_customer' -%}
        {%- if form.errors -%}
          <div style="background: #FEE2E2; color: #B91C1C; padding: 0.75rem 1rem; border-radius: var(--btn-border-radius); margin-bottom: 1.5rem; font-size: 0.875rem;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="field" style="margin-bottom: 1rem; text-align: left;">
          <label class="field__label" for="FirstName">First name</label>
          <input type="text" id="FirstName" name="customer[first_name]" class="field__input" autocomplete="given-name" required>
        </div>

        <div class="field" style="margin-bottom: 1rem; text-align: left;">
          <label class="field__label" for="LastName">Last name</label>
          <input type="text" id="LastName" name="customer[last_name]" class="field__input" autocomplete="family-name" required>
        </div>

        <div class="field" style="margin-bottom: 1rem; text-align: left;">
          <label class="field__label" for="Email">Email</label>
          <input type="email" id="Email" name="customer[email]" class="field__input" autocomplete="email" required>
        </div>

        <div class="field" style="margin-bottom: 1.5rem; text-align: left;">
          <label class="field__label" for="Password">Password</label>
          <input type="password" id="Password" name="customer[password]" class="field__input" autocomplete="new-password" required>
        </div>

        <button type="submit" class="btn btn--primary btn--full">Create Account</button>

        <p style="margin-top: 1.5rem; font-size: 0.875rem; color: var(--color-text-light);">
          Already have an account? <a href="{{ routes.account_login_url }}" style="font-weight: 600;">Sign in</a>
        </p>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer register",
  "tag": "section",
  "settings": []
}
{% endschema %}
