<div class="section" style="min-height: 80vh; display: flex; align-items: center;">
  <div class="page-width">
    <div style="text-align: center; max-width: 500px; margin: 0 auto;">
      <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{{ shop.name }}</h1>
      <p style="font-size: 1.125rem; color: var(--color-text-light); margin-bottom: 2rem;">
        {{ 'general.password_page.opening_soon' | t | default: 'We are opening soon' }}
      </p>

      {%- if shop.password_message != blank -%}
        <div style="margin-bottom: 2rem; line-height: 1.7;">{{ shop.password_message }}</div>
      {%- endif -%}

      {%- form 'storefront_password' -%}
        <div style="display: flex; gap: 0.75rem; max-width: 400px; margin: 0 auto;">
          <input
            type="password"
            name="password"
            class="field__input"
            placeholder="Enter password"
            required
          >
          <button type="submit" class="btn btn--primary">Enter</button>
        </div>
        {%- if form.errors -%}
          <p style="color: var(--color-accent); margin-top: 0.75rem; font-size: 0.875rem;">
            {{ form.errors.messages['password'] }}
          </p>
        {%- endif -%}
      {%- endform -%}

      <p style="margin-top: 3rem; font-size: 0.8125rem; color: var(--color-text-light);">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "section-password",
  "settings": []
}
{% endschema %}
