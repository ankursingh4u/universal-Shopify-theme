<div class="section">
  <div class="page-width">
    <div style="max-width: 450px; margin: 0 auto; text-align: center;">
      <h1 style="margin-bottom: 1rem;">Reset Password</h1>
      <p style="margin-bottom: 2rem; color: var(--color-text-light);">Enter a new password for your account.</p>

      {%- form 'reset_customer_password' -%}
        <div class="field" style="margin-bottom: 1rem; text-align: left;">
          <label class="field__label" for="Password">New password</label>
          <input type="password" id="Password" name="customer[password]" class="field__input" required>
        </div>
        <div class="field" style="margin-bottom: 1.5rem; text-align: left;">
          <label class="field__label" for="PasswordConfirm">Confirm new password</label>
          <input type="password" id="PasswordConfirm" name="customer[password_confirmation]" class="field__input" required>
        </div>
        <button type="submit" class="btn btn--primary btn--full">Reset Password</button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Reset password",
  "tag": "section",
  "settings": []
}
{% endschema %}
