{%- comment -%}
  NICHE VALUE OUTPUT ENGINE
  =========================
  Outputs a single niche-specific value based on `key` parameter.
  Uses the capture pattern to work with render's isolated scope.

  Usage:
    {%- capture my_var -%}{%- render 'niche-value', key: 'hero_heading' -%}{%- endcapture -%}
    {{ my_var }}

  Supported keys:
    hero_heading, hero_subheading,
    about_heading, about_text,
    newsletter_heading, newsletter_subheading,
    feature_1_title, feature_1_text, feature_2_title, feature_2_text, feature_3_title, feature_3_text,
    testimonial_1_text, testimonial_1_author, testimonial_2_text, testimonial_2_author, testimonial_3_text, testimonial_3_author,
    faq_1_q, faq_1_a, faq_2_q, faq_2_a, faq_3_q, faq_3_a, faq_4_q, faq_4_a,
    cat_1, cat_2, cat_3,
    color_primary, color_accent, color_heading, color_bg,
    hero_image, story_image, cat_1_image, cat_2_image, cat_3_image
{%- endcomment -%}
{%- case settings.store_niche -%}

