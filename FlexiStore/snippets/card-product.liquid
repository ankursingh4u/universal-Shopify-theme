{% comment %}
  Renders a product card.

  Accepts:
  - product: {Object} Shopify product object
  - show_vendor: {Boolean} Show vendor name
  - show_secondary_image: {Boolean} Show second image on hover
  - show_badge: {Boolean} Show sale/sold out badge
  - show_quick_add: {Boolean} Show quick add button
  - image_ratio: {String} 'portrait' | 'square' | 'landscape' | 'adapt'
  - card_style: {String} 'standard' | 'bordered' | 'shadow'

  Usage:
  {% render 'card-product', product: product %}
{% endcomment %}

{%- liquid
  assign show_vendor = show_vendor | default: settings.card_show_vendor
  assign show_secondary_image = show_secondary_image | default: settings.card_show_secondary_image
  assign show_badge = show_badge | default: settings.card_show_badge
  assign show_quick_add = show_quick_add | default: settings.card_show_quick_add
  assign image_ratio = image_ratio | default: settings.card_image_ratio
  assign card_style = card_style | default: settings.card_style
  assign on_sale = false
  assign sold_out = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif
  unless product.available
    assign sold_out = true
  endunless
-%}

<div class="card card--{{ card_style }}">
  <div class="card__media card__media--{{ image_ratio }}">
    <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | escape }}"
          loading="lazy"
          width="600"
          height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

      {%- if show_secondary_image and product.images[1] -%}
        <img
          class="card__media-secondary"
          src="{{ product.images[1] | image_url: width: 600 }}"
          alt="{{ product.images[1].alt | escape }}"
          loading="lazy"
          width="600"
          height="{{ 600 | divided_by: product.images[1].aspect_ratio | round }}"
        >
      {%- endif -%}
    </a>

    {%- if show_badge -%}
      {%- if sold_out -%}
        <span class="card__badge card__badge--sold-out">{{ 'products.product.sold_out' | t }}</span>
      {%- elsif on_sale -%}
        <span class="card__badge card__badge--sale">{{ 'products.product.on_sale' | t }}</span>
      {%- endif -%}
    {%- endif -%}
  </div>

  <div class="card__content">
    {%- if show_vendor and product.vendor != blank -%}
      <p class="card__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h3 class="card__title">
      <a href="{{ product.url }}">{{ product.title | escape }}</a>
    </h3>

    <div class="card__price{% if on_sale %} card__price--on-sale{% endif %}">
      {%- if on_sale -%}
        <span class="card__price-sale">{{ product.price | money }}</span>
        <span class="card__price-regular">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        <span>
          {%- if product.price_varies -%}
            {%- assign min_price = product.price_min | money -%}
            {{ 'general.from_price' | t: price: min_price }}
          {%- else -%}
            {{ product.price | money }}
          {%- endif -%}
        </span>
      {%- endif -%}
    </div>

    {%- if show_quick_add and product.available -%}
      <div class="card__quick-add">
        {%- if product.variants.size == 1 -%}
          <button class="btn btn--primary btn--small btn--full" data-quick-add="{{ product.variants.first.id }}">
            {{ 'products.product.quick_add' | t }}
          </button>
        {%- else -%}
          <a href="{{ product.url }}" class="btn btn--secondary btn--small btn--full">
            {{ 'products.product.quick_add' | t }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>
