{% comment %}
  Cart Drawer – rendered in theme.liquid when cart_type == 'drawer'
{% endcomment %}

<div class="cart-drawer" data-cart-drawer>
  <div class="cart-drawer__overlay"></div>
  <div class="cart-drawer__panel">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">{{ 'cart.general.title' | t }} ({{ cart.item_count }})</h2>
      <button class="cart-drawer__close" data-cart-drawer-close aria-label="{{ 'accessibility.close_modal' | t }}">
        {% render 'icon-close' %}
      </button>
    </div>

    <div class="cart-drawer__items" data-cart-drawer-items>
      {%- if cart.items.size > 0 -%}
        {%- for item in cart.items -%}
          <div class="cart-drawer__item">
            <div class="cart-drawer__item-media">
              <a href="{{ item.url }}">
                {%- if item.image -%}
                  <img
                    src="{{ item.image | image_url: width: 160 }}"
                    alt="{{ item.title | escape }}"
                    loading="lazy"
                    width="72"
                    height="72"
                  >
                {%- endif -%}
              </a>
            </div>
            <div class="cart-drawer__item-info">
              <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title | escape }}</a>
              {%- if item.variant.title != 'Default Title' -%}
                <span class="cart-drawer__item-variant">{{ item.variant.title }}</span>
              {%- endif -%}
              <span class="cart-drawer__item-price">{{ item.final_line_price | money }}</span>
              <div class="cart-drawer__item-actions">
                <div class="product__quantity">
                  <button class="product__quantity-btn" data-drawer-qty-minus="{{ forloop.index }}" aria-label="{{ 'accessibility.decrease_quantity' | t }}">-</button>
                  <input type="number" class="product__quantity-input" value="{{ item.quantity }}" min="0" readonly>
                  <button class="product__quantity-btn" data-drawer-qty-plus="{{ forloop.index }}" aria-label="{{ 'accessibility.increase_quantity' | t }}">+</button>
                </div>
                <button class="cart__item-remove" data-drawer-remove="{{ forloop.index }}">{{ 'cart.general.remove' | t }}</button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="cart-drawer__empty">
          <p>{{ 'cart.general.empty' | t }}</p>
        </div>
      {%- endif -%}
    </div>

    <div class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span>{{ 'cart.general.subtotal' | t }}</span>
        <span data-cart-drawer-subtotal>{{ cart.total_price | money }}</span>
      </div>
      <p class="text-light" style="font-size: 0.8125rem; margin-bottom: 1rem;">{{ 'cart.general.taxes_note' | t }}</p>
      <a href="/checkout" class="btn btn--primary btn--full">{{ 'cart.general.checkout' | t }}</a>
      <a href="/collections/all" class="btn btn--secondary btn--full" style="margin-top: 0.5rem;">{{ 'cart.general.continue_shopping' | t }}</a>
    </div>
  </div>
</div>
