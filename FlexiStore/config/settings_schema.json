  {
    "name": "Store Niche",
    "settings": [
      {
        "type": "paragraph",
        "content": "Choose your store niche. The theme will automatically adapt its content, colors, and messaging to match your industry. You can always override anything manually."
      },
      {
        "type": "select",
        "id": "store_niche",
        "label": "Store niche",
        "options": [
          {
            "value": "general",
            "label": "General / Multi-purpose"
          },
          {
            "value": "fashion",
            "label": "Fashion & Clothing"
          },
          {
            "value": "shoes",
            "label": "Shoes & Footwear"
          },
          {
            "value": "baby",
            "label": "Baby & Kids"
          },
          {
            "value": "toys",
            "label": "Toys & Games"
          },
          {
            "value": "kitchen",
            "label": "Kitchen & Home"
          },
          {
            "value": "electronics",
            "label": "Electronics & Tech"
          },
          {
            "value": "beauty",
            "label": "Beauty & Skincare"
          },
          {
            "value": "sports",
            "label": "Sports & Fitness"
          },
          {
            "value": "jewelry",
            "label": "Jewelry & Accessories"
          },
          {
            "value": "pets",
            "label": "Pets & Animals"
          },
          {
            "value": "food",
            "label": "Food & Grocery"
          },
          {
            "value": "furniture",
            "label": "Furniture & Decor"
          }
