<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ request.locale.text_direction }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {% comment %} Niche color capture {% endcomment %}
  {%- capture niche_c_primary -%}{%- render 'niche-value', key: 'color_primary' -%}{%- endcapture -%}
  {%- capture niche_c_accent -%}{%- render 'niche-value', key: 'color_accent' -%}{%- endcapture -%}
  {%- capture niche_c_heading -%}{%- render 'niche-value', key: 'color_heading' -%}{%- endcapture -%}
  {%- capture niche_c_bg -%}{%- render 'niche-value', key: 'color_bg' -%}{%- endcapture -%}

  {% comment %} CSS Variables from theme settings {% endcomment %}
  <style>
    :root {
      {%- if settings.niche_colors and settings.store_niche != 'general' -%}
        --color-primary: {{ niche_c_primary | strip }};
        --color-accent: {{ niche_c_accent | strip }};
        --color-heading: {{ niche_c_heading | strip }};
        --color-background: {{ niche_c_bg | strip }};
      {%- else -%}
        --color-primary: {{ settings.color_primary }};
        --color-accent: {{ settings.color_accent }};
        --color-heading: {{ settings.color_heading }};
        --color-background: {{ settings.color_background }};
      {%- endif -%}
      --color-secondary: {{ settings.color_secondary }};
      --color-background-alt: {{ settings.color_background_alt }};
      --color-text: {{ settings.color_text }};
      --color-text-light: {{ settings.color_text_light }};
      --color-border: {{ settings.color_border }};

      --font-heading: {{ settings.font_heading.family | default: 'Assistant' }}, {{ settings.font_heading.fallback_families | default: 'sans-serif' }};
      --font-heading-weight: {{ settings.heading_weight }};
      --font-heading-transform: {{ settings.heading_transform }};
      --font-body: {{ settings.font_body.family | default: 'Assistant' }}, {{ settings.font_body.fallback_families | default: 'sans-serif' }};
      --font-body-size: {{ settings.font_body_size }}px;

      {%- if settings.niche_colors and settings.store_niche != 'general' -%}
        --btn-primary-bg: {{ niche_c_primary | strip }};
        --btn-primary-text: #FFFFFF;
        --btn-secondary-bg: transparent;
        --btn-secondary-text: {{ niche_c_primary | strip }};
        --btn-secondary-border: {{ niche_c_primary | strip }};
      {%- else -%}
        --btn-primary-bg: {{ settings.btn_primary_bg }};
        --btn-primary-text: {{ settings.btn_primary_text }};
        --btn-secondary-bg: {{ settings.btn_secondary_bg }};
        --btn-secondary-text: {{ settings.btn_secondary_text }};
        --btn-secondary-border: {{ settings.btn_secondary_border }};
      {%- endif -%}
      --btn-border-radius: {{ settings.btn_border_radius }}px;
      --btn-padding: {{ settings.btn_padding_vertical }}px {{ settings.btn_padding_horizontal }}px;

      --page-width: {{ settings.page_width }}px;
      --section-spacing: {{ settings.section_spacing }}px;
      --grid-gap: {{ settings.grid_gap }}px;
    }
  </style>

  <style>
    {%- if settings.font_heading.family -%}
      {{ settings.font_heading | font_face: font_display: 'swap' }}
    {%- endif -%}
    {%- if settings.font_body.family -%}
      {{ settings.font_body | font_face: font_display: 'swap' }}
    {%- endif -%}
  </style>

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
  </script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a class="skip-to-content" href="#MainContent">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {% sections 'header-group' %}

  <main id="MainContent" class="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {%- if settings.cart_type == 'drawer' -%}
    {% render 'cart-drawer' %}
  {%- endif -%}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
